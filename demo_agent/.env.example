# D365 Demo Copilot — Environment Configuration
# Copy this to .env and fill in your credentials

# ---- D365 Environment ----
D365_BASE_URL=https://projectopscoreagentimplemented.crm.dynamics.com

# ---- Azure OpenAI (recommended) ----
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-10-21
LLM_MODEL=gpt-4o

# ---- OR Standard OpenAI ----
# OPENAI_API_KEY=

# ---- Browser ----
BROWSER_HEADLESS=false
BROWSER_SLOW_MO=50
AUTH_STATE_PATH=auth_state.json

# ---- Voice Narration (TTS) ----
# Default: Edge TTS (free, no API key needed, Microsoft neural voices)
# Optional upgrade: OpenAI TTS (requires VOICE_API_KEY or OPENAI_API_KEY)
#
# VOICE_ENABLED=false          # Enable voice narration (can also toggle in sidecar)
# VOICE_PROVIDER=auto          # auto (OpenAI if key set, else Edge), edge, openai
# VOICE_NAME=nova              # Voice: alloy, echo, fable, onyx, nova, shimmer
# VOICE_SPEED=1.0              # Playback speed (0.25 to 4.0)
# VOICE_MODEL=tts-1            # OpenAI only: tts-1 or tts-1-hd
# VOICE_API_KEY=               # OpenAI only: dedicated TTS API key
